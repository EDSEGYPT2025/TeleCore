@page
@model TeleCore.APIServer.Pages.CashierDashboardModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "لوحة الكاشير";
}

<div class="container mt-5" dir="rtl" style="max-width: 650px;">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-dark text-white text-center py-3">
            <h4 class="mb-0"><i class="bi bi-wallet2"></i> تنفيذ عملية تحويل أوتوماتيكية</h4>
        </div>
        <div class="card-body p-4">

            @* مكان عرض الرسائل اللحظية من SignalR *@
            <div id="liveAlert" class="alert d-none text-center fw-bold fs-5"></div>

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") text-center fw-bold fs-5" id="serverMessage">
                    @Model.StatusMessage
                </div>
            }

            <form method="post" id="transferForm">
                <div class="mb-4">
                    <label class="form-label fw-bold">اختر الشريحة (المحفظة)</label>
                    <select asp-for="SelectedSimId" asp-items="Model.AvailableSims" class="form-select form-select-lg" required>
                        <option value="">-- اختر الشريحة --</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">رقم هاتف العميل</label>
                    <input type="text" asp-for="TargetNumber" class="form-control form-control-lg text-center" placeholder="010XXXXXXXX" required dir="ltr" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">المبلغ المطلوب (جنيه)</label>
                    <input type="number" asp-for="Amount" class="form-control form-control-lg text-center" placeholder="150" required min="1" dir="ltr" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-danger">الرقم السري للمحفظة (PIN)</label>
                    <input type="password" asp-for="ClearPin" class="form-control form-control-lg text-center" placeholder="****" required dir="ltr" />
                    <div class="form-text text-muted mt-2">
                        <i class="bi bi-shield-lock-fill text-success"></i> سيتم تشفير هذا الرقم آلياً (End-to-End Encryption).
                    </div>
                </div>

                <hr />

                <button type="submit" id="submitBtn" class="btn btn-success btn-lg w-100 fw-bold shadow-sm">
                    تأكيد وتنفيذ العملية عبر الموبايل <i class="bi bi-send-check"></i>
                </button>
            </form>
        </div>
    </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    // ✅ التصحيح هنا
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/transferHub")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveTransactionResult", function (message) {
        const alertBox = document.getElementById("liveAlert");
        alertBox.classList.remove("d-none", "alert-success", "alert-danger", "alert-info");
        alertBox.add(message.includes("نجاح") ? "alert-success" : "alert-info");
        alertBox.innerHTML = `<b>تحديث مباشر:</b> ${message}`;
    });

    connection.start().then(function () {
        console.log("Dashboard Connected!");
        // 🔍 فحص فوري: اسأل السيرفر مين متصل دلوقتي؟
        connection.invoke("GetOnlineSims").then(function (sims) {
            console.log("الشرائح المتصلة حالياً: ", sims);
        });
    }).catch(err => console.error("SignalR Error: " + err.toString()));
</script>