@page
@model TeleCore.APIServer.Pages.CashierDashboardModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "COMMAND CENTER | لوحة التحكم العسكرية";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-dark: #050b14;
            --panel-bg: rgba(10, 15, 25, 0.95);
            --neon-cyan: #00f0ff;
            --neon-green: #39ff14;
            --neon-red: #ff003c;
            --neon-yellow: #ffc107;
            --border-color: #1a2a40;
            --text-main: #e2e8f0;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Cairo', sans-serif;
            background-image: linear-gradient(rgba(0, 240, 255, 0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 240, 255, 0.02) 1px, transparent 1px);
            background-size: 40px 40px;
            min-height: 100vh;
            overflow-y: auto;
            padding-bottom: 50px;
        }

        .tech-font {
            font-family: 'Share Tech Mono', monospace;
        }

        .hud-panel {
            background: var(--panel-bg);
            border: 1px solid var(--border-color);
            box-shadow: inset 0 0 20px rgba(0, 240, 255, 0.05);
            min-height: 80vh;
            display: flex;
            flex-direction: column;
            margin-bottom: 20px;
        }

        .hud-header {
            border-bottom: 1px solid rgba(0, 240, 255, 0.2);
            color: var(--neon-cyan);
            padding: 12px 15px;
            font-weight: 900;
            background: rgba(0, 240, 255, 0.05);
            text-transform: uppercase;
        }

        .scrollable-content {
            padding: 20px;
            overflow-y: auto;
            flex-grow: 1;
        }

        .status-light {
            height: 14px;
            width: 14px;
            border-radius: 50%;
            display: inline-block;
            background-color: var(--neon-red);
            box-shadow: 0 0 10px var(--neon-red);
            transition: all 0.4s ease-in-out;
        }

            .status-light.online {
                background-color: var(--neon-green) !important;
                box-shadow: 0 0 15px var(--neon-green) !important;
                animation: blink-green 1.5s infinite !important;
            }

        @@keyframes blink-green {
            0% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.4;
                transform: scale(1.2);
            }

            100% {
                opacity: 1;
                transform: scale(1);
            }
        }

        .sim-node-card {
            background: rgba(0,0,0,0.5);
            border: 1px solid var(--border-color);
            padding: 15px;
            margin-bottom: 12px;
        }

        .hud-input {
            background: rgba(0, 0, 0, 0.7) !important;
            border: 1px solid var(--border-color) !important;
            color: var(--neon-cyan) !important;
            border-radius: 0;
            padding: 12px;
        }

        .btn-launch {
            background: rgba(0, 240, 255, 0.1);
            color: var(--neon-cyan);
            border: 1px solid var(--neon-cyan);
            font-weight: 900;
            border-radius: 0;
            padding: 15px;
        }

        /* زر الصوت */
        .btn-audio-toggle {
            background: transparent;
            color: var(--neon-yellow);
            border: 1px solid var(--neon-yellow);
            font-size: 12px;
            padding: 2px 10px;
            cursor: pointer;
        }

            .btn-audio-toggle.enabled {
                color: var(--neon-green);
                border-color: var(--neon-green);
            }

        .log-row-pending {
            background: rgba(255, 193, 7, 0.1) !important;
            color: var(--neon-yellow) !important;
            border-right: 4px solid var(--neon-yellow);
        }

        .log-row-success {
            background: rgba(57, 255, 20, 0.05) !important;
            color: var(--neon-green) !important;
            border-right: 4px solid var(--neon-green);
        }

        .log-row-error {
            background: rgba(255, 0, 60, 0.1) !important;
            color: var(--neon-red) !important;
            border-right: 4px solid var(--neon-red);
        }

        .update-anim {
            animation: pulse-update 1s ease-out;
        }

        @@keyframes pulse-update {
            0% {
                filter: brightness(2.5);
                transform: scale(1.02);
            }

            100% {
                filter: brightness(1);
                transform: scale(1);
            }
        }

        #liveAlertBox {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            min-width: 400px;
            display: none;
            border-radius: 0;
            box-shadow: 0 0 30px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>

    <div id="liveAlertBox" class="alert tech-font text-center"></div>

    <div class="container-fluid p-3">
        <div class="row mb-3 align-items-center" style="border-bottom: 2px solid var(--border-color); padding-bottom: 15px;">
            <div class="col-md-4"><h3 class="m-0 tech-font" style="color: var(--neon-cyan);"><i class="bi bi-cpu-fill"></i> TELECORE_SYS</h3></div>
            <div class="col-md-4 text-center">
                <div class="d-inline-block px-3 py-1 border border-secondary bg-dark">
                    <span class="status-light online me-2"></span>
                    <span class="tech-font small" style="color:var(--neon-green)">NETWORK: ACTIVE</span>
                    <button id="enableAudio" class="btn-audio-toggle ms-2 tech-font">
                        <i class="bi bi-volume-mute"></i> ENABLE_SOUND
                    </button>
                </div>
            </div>
            <div class="col-md-4 text-start"><span class="text-muted tech-font small">OPERATOR: @User.Identity?.Name?.ToUpper()</span></div>
        </div>

        <div class="row g-3">
            <div class="col-md-3">
                <div class="hud-panel">
                    <div class="hud-header">> SIM_NODES</div>
                    <div class="scrollable-content">
                        @if (Model.AvailableSims != null)
                        {
                            @foreach (var sim in Model.AvailableSims)
                            {
                                <div class="sim-node-card" id="node-@sim.Value">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <div class="tech-font text-white">@sim.Text.Split('(')[0]</div>
                                            <small class="text-muted tech-font" id="status-text-@sim.Value">STATUS: OFFLINE</small>
                                        </div>
                                        <span class="status-light" id="light-@sim.Value"></span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="hud-panel">
                    <div class="hud-header">> EXECUTE_TRANSFER</div>
                    <div class="scrollable-content">
                        <form id="transferForm">
                            @Html.AntiForgeryToken()
                            <div class="mb-4">
                                <label class="form-label tech-font text-muted small">> SELECT_CHANNEL</label>
                                <select asp-for="SelectedSimId" asp-items="Model.AvailableSims" class="form-select hud-input tech-font" required id="inputSim">
                                    <option value="">-- SELECT SOURCE --</option>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label class="form-label tech-font text-muted small">> TARGET_ACCOUNT</label>
                                <input asp-for="TargetNumber" id="inputTarget" class="form-control hud-input text-center fs-4 tech-font" placeholder="01XXXXXXXXX" required />
                            </div>
                            <div class="mb-4">
                                <label class="form-label tech-font text-muted small">> AMOUNT_EGP</label>
                                <input asp-for="Amount" id="inputAmount" class="form-control hud-input text-center fs-2 tech-font" placeholder="0.00" required />
                            </div>
                            <div class="mb-4">
                                <label class="form-label tech-font text-muted small">> ENCRYPTION_PIN</label>
                                <input type="password" asp-for="ClearPin" id="inputPin" class="form-control hud-input text-center" placeholder="****" required />
                            </div>
                            <button type="submit" id="submitBtn" class="btn btn-launch w-100">
                                <i class="bi bi-shield-lock"></i> [ START_EXECUTION ]
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="hud-panel">
                    <div class="hud-header">> REALTIME_LOGS</div>
                    <div class="scrollable-content p-0">
                        <table class="table log-table table-borderless m-0 text-center text-white">
                            <thead class="sticky-top bg-dark border-bottom border-secondary">
                                <tr class="tech-font"><th>#REF</th><th>TARGET</th><th>VALUE</th><th>STATUS</th></tr>
                            </thead>
                            <tbody id="liveLogBody">
                                <tr><td colspan="4" class="text-muted py-5 tech-font small">SCANNING_FOR_SIGNALS...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // --- تهيئة الصوت ---
        let audioEnabled = false;
        const successAudio = new Audio('https://actions.google.com/sounds/v1/communication/notification_high_intensity.ogg');
        const errorAudio = new Audio('https://actions.google.com/sounds/v1/alarms/beep_short.ogg');

        document.getElementById('enableAudio').addEventListener('click', function() {
            audioEnabled = true;
            this.innerHTML = '<i class="bi bi-volume-up"></i> SOUND_ON';
            this.classList.add('enabled');
            // تشغيل صوت صامت لتفعيل الإذن
            successAudio.play().then(() => { successAudio.pause(); successAudio.currentTime = 0; });
        });

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/transferHub")
            .withAutomaticReconnect()
            .build();

        // 1. معالجة AJAX مع نظام اصطياد الأخطاء ومؤقت الأمان (Timeout)
        document.getElementById("transferForm").onsubmit = async function(e) {
            e.preventDefault();
            const target = document.getElementById("inputTarget").value;
            const amount = document.getElementById("inputAmount").value;
            const logBody = document.getElementById("liveLogBody");
            const btn = document.getElementById("submitBtn");

            // إنشاء سطر Pending
            if (logBody.innerHTML.includes("SCANNING")) logBody.innerHTML = "";
            const pendingRow = `<tr id="row-${target}" class="log-row-pending tech-font"><td>#WAIT</td><td class="fs-6">${target}</td><td class="fw-bold text-white">${amount} <span class="small text-muted">EGP</span></td><td class="status-cell"><span class="spinner-border spinner-border-sm text-warning me-1"></span> PENDING</td></tr>`;
            logBody.insertAdjacentHTML('afterbegin', pendingRow);

            btn.innerHTML = "[ PROCESSING... ]";
            btn.classList.add("disabled");

            const formData = new FormData(this);

            try {
                // إرسال الطلب
                const response = await fetch('', {
                    method: 'POST',
                    body: formData,
                    headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value }
                });

                // إذا السيرفر رفض الطلب (مثلاً الباسورد خطأ في طبقة السيرفر)
                if (!response.ok) {
                    throw new Error("Server Rejected: Status " + response.status);
                }

                // ⏱️ 🔥 إضافة "مؤقت الأمان": إذا لم يرد الموبايل خلال 40 ثانية
                setTimeout(() => {
                    let row = document.getElementById(`row-${target}`);
                    // نفحص: هل السطر ما زال PENDING؟ (يعني الموبايل لم يرد)
                    if (row && row.classList.contains("log-row-pending")) {
                        console.log("⚠️ Transaction Timeout triggered for: " + target);

                        // تحويل حالة السطر إلى خطأ/تأخير
                        row.className = "log-row-error tech-font update-anim";
                        row.cells[0].innerText = "#TIME";
                        row.querySelector(".status-cell").innerHTML = `<i class="bi bi-clock-history"></i> TIMEOUT`;

                        // إعادة الزر للعمل
                        btn.innerHTML = "<i class='bi bi-shield-lock'></i> [ START_EXECUTION ]";
                        btn.classList.remove("disabled");

                        // تنبيه الكاشير
                        const alertBox = document.getElementById("liveAlertBox");
                        alertBox.style.display = "block";
                        alertBox.className = "alert alert-warning tech-font text-center shadow-lg";
                        alertBox.innerHTML = `<i class="bi bi-hourglass-bottom me-2 fs-5"></i> <strong>SYSTEM_TIMEOUT:</strong> الموبايل لم يرد (تأكد من الرقم السري أو الشبكة).`;
                        setTimeout(() => { alertBox.style.display = "none"; }, 8000);

                        if (audioEnabled) errorAudio.play().catch(()=>{});
                    }
                }, 40000); // 40 ثانية

            } catch (err) {
                console.error("Transmission Error:", err);

                // 🚨 معالجة الخطأ المباشر للاتصال
                let row = document.getElementById(`row-${target}`);
                if (row) {
                    row.className = "log-row-error tech-font update-anim";
                    row.cells[0].innerText = "#ERR";
                    row.querySelector(".status-cell").innerHTML = `<i class="bi bi-x-octagon-fill"></i> REJECTED`;
                }

                // إعادة تفعيل الزر لعدم تجميد الشاشة
                btn.innerHTML = "<i class='bi bi-shield-lock'></i> [ START_EXECUTION ]";
                btn.classList.remove("disabled");

                // إظهار إشعار بخطأ الإرسال
                const alertBox = document.getElementById("liveAlertBox");
                alertBox.style.display = "block";
                alertBox.className = "alert alert-danger tech-font text-center shadow-lg";
                alertBox.innerHTML = `<i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> <strong>SYSTEM_ERROR:</strong> تعذر التنفيذ، يرجى مراجعة البيانات.`;
                setTimeout(() => { alertBox.style.display = "none"; }, 5000);

                if (audioEnabled) errorAudio.play().catch(()=>{});
            }
        };

        // 2. استقبال النتيجة من الـ SignalR
        connection.on("ReceiveTransactionResult", function (status, message, target, amount) {
            if (message.includes("RefreshHistory") || message.trim() === "") return;

            const isSuccess = status === "Completed";
            let row = document.getElementById(`row-${target}`);

            // تنظيف الرسالة
            let cleanMessage = message;
            if (message.includes("تم تحويل")) {
                const parts = message.split('.');
                cleanMessage = parts.find(p => p.includes("تم تحويل") && p.includes(target)) || parts[0];
            } else if (message.length > 150) {
                cleanMessage = message.substring(0, 100) + "...";
            }

            if (row) {
                row.className = `tech-font update-anim ${isSuccess ? 'log-row-success' : 'log-row-error'}`;
                row.cells[0].innerText = "#" + Math.floor(Math.random() * 9000 + 1000);
                row.querySelector(".status-cell").innerHTML = `<i class="bi ${isSuccess ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill'}"></i> ${isSuccess ? "EXECUTED" : "FAILED"}`;
            }

            const alertBox = document.getElementById("liveAlertBox");
            alertBox.style.display = "block";
            alertBox.className = `alert tech-font text-center shadow-lg ${isSuccess ? 'alert-success' : 'alert-danger'}`;
            alertBox.innerHTML = `<div class="d-flex align-items-center justify-content-center"><i class="bi bi-megaphone-fill me-2 fs-4"></i><div class="text-start"><strong>STATUS: ${isSuccess ? 'SUCCESS' : 'NOTICE'}</strong><br><small>${cleanMessage}</small></div></div>`;

            const submitBtn = document.getElementById("submitBtn");
            submitBtn.innerHTML = "<i class='bi bi-shield-lock'></i> [ START_EXECUTION ]";
            submitBtn.classList.remove("disabled");

            if (isSuccess) {
                document.getElementById("inputTarget").value = "";
                document.getElementById("inputAmount").value = "";
            }

            setTimeout(() => { alertBox.style.display = "none"; }, 12000);

            // تشغيل الصوت إذا تم التفعيل
            if (audioEnabled) {
                const sound = isSuccess ? successAudio : errorAudio;
                sound.play().catch(e => console.warn("Audio play blocked"));
            }
        });

        function updateNodeStatus(simId, isOnline) {
            const light = document.getElementById("light-" + simId);
            const text = document.getElementById("status-text-" + simId);
            if (light && text) {
                light.className = isOnline ? "status-light online" : "status-light";
                text.innerText = isOnline ? "STATUS: ONLINE" : "STATUS: OFFLINE";
                text.style.color = isOnline ? "var(--neon-green)" : "var(--neon-red)";
            }
        }

        connection.on("NodeStatusChanged", (id, status) => updateNodeStatus(id, status === "Online"));
        connection.start().then(() => {
            connection.invoke("GetOnlineSims").then(ids => ids.forEach(id => updateNodeStatus(id, true)));
        });
    </script>
</body>
</html>