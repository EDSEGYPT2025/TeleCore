<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCore.Mobile.Pages.HistoryPage"
             Title="سجل العمليات"
             BackgroundColor="#F8F9FA"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="160, Auto, *">
        <BoxView Grid.Row="0" BackgroundColor="#E60000" CornerRadius="0,0,30,30" VerticalOptions="FillAndExpand"/>
        <VerticalStackLayout Grid.Row="0" Padding="25" Spacing="5" VerticalOptions="Center">
            <Label Text="سجل المعاملات" TextColor="White" FontSize="28" FontAttributes="Bold" />
            <Label Text="إدارة مدفوعاتك وتحويلاتك في مكان واحد" TextColor="#FFCCCC" FontSize="14"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="15,-30,15,10">
            <HorizontalStackLayout Spacing="12" Padding="5">
                <Button x:Name="BtnAll" Text="الكل" CommandParameter="الكل" Clicked="OnFilterClicked"
                        CornerRadius="12" HeightRequest="45" WidthRequest="90" FontSize="14" FontAttributes="Bold"
                        BackgroundColor="#1E293B" TextColor="White" />

                <Button x:Name="BtnIncoming" Text="الوارد ↓" CommandParameter="استقبال" Clicked="OnFilterClicked"
                        CornerRadius="12" HeightRequest="45" WidthRequest="100" FontSize="14" FontAttributes="Bold"
                        BackgroundColor="White" TextColor="#475569" BorderColor="#E2E8F0" BorderWidth="1"/>

                <Button x:Name="BtnOutgoing" Text="الصادر ↑" CommandParameter="تحويل" Clicked="OnFilterClicked"
                        CornerRadius="12" HeightRequest="45" WidthRequest="100" FontSize="14" FontAttributes="Bold"
                        BackgroundColor="White" TextColor="#475569" BorderColor="#E2E8F0" BorderWidth="1"/>
            </HorizontalStackLayout>
        </ScrollView>

        <CollectionView Grid.Row="2" x:Name="TransactionsList" Margin="20,10,20,0">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="0" CornerRadius="20" HasShadow="False" BorderColor="#F1F5F9" BackgroundColor="White" Margin="0,5">
                        <VerticalStackLayout>
                            <Grid Padding="15,20" ColumnDefinitions="110, *, 60" VerticalOptions="Center">

                                <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center" HorizontalOptions="Start">
                                    <Label FontSize="19" FontAttributes="Bold">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="استقبال">
                                                <Setter Property="Text" Value="{Binding Amount, StringFormat='+ {0} ج'}" />
                                                <Setter Property="TextColor" Value="#10B981" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="تحويل">
                                                <Setter Property="Text" Value="{Binding Amount, StringFormat='- {0} ج'}" />
                                                <Setter Property="TextColor" Value="#EF4444" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Border Padding="8,3" StrokeThickness="0" HorizontalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6"/>
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding Type}" Value="استقبال">
                                                <Setter Property="BackgroundColor" Value="#DCFCE7"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding Type}" Value="تحويل">
                                                <Setter Property="BackgroundColor" Value="#F1F5F9"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label FontSize="10" FontAttributes="Bold">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="استقبال">
                                                    <Setter Property="Text" Value="إيداع وارد"/>
                                                    <Setter Property="TextColor" Value="#065F46"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="تحويل">
                                                    <Setter Property="Text" Value="تحويل صادر"/>
                                                    <Setter Property="TextColor" Value="#475569"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Margin="10,0">
                                    <Label Text="{Binding ReceiverName}" 
                                           FontSize="15" 
                                           FontAttributes="Bold" 
                                           TextColor="#1E293B" 
                                           HorizontalOptions="Start"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"/>

                                    <Label Text="{Binding ReceiverNumber, StringFormat='رقم: {0}'}" 
                                           FontSize="11" 
                                           TextColor="#64748B" 
                                           FontAttributes="Bold" 
                                           HorizontalOptions="Start"/>

                                    <HorizontalStackLayout Spacing="5" HorizontalOptions="Start">
                                        <Label Text="{Binding TransactionId, StringFormat='عملية: {0}'}" FontSize="10" TextColor="#94A3B8" FontAttributes="Bold"/>
                                        <Label Text="•" TextColor="#CBD5E1"/>
                                        <Label Text="{Binding Timestamp, StringFormat='{0:MM/dd hh:mm}'}" FontSize="10" TextColor="#94A3B8"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Border Grid.Column="2" HeightRequest="50" WidthRequest="50" StrokeThickness="0" VerticalOptions="Center" HorizontalOptions="End">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="25"/>
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding Type}" Value="استقبال">
                                            <Setter Property="BackgroundColor" Value="#E8FDF3"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding Type}" Value="تحويل">
                                            <Setter Property="BackgroundColor" Value="#FEF2F2"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label HorizontalOptions="Center" VerticalOptions="Center" FontSize="22">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="استقبال">
                                                <Setter Property="Text" Value="📥"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="تحويل">
                                                <Setter Property="Text" Value="📤"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F1F5F9" Margin="15,0"/>
                            <Grid Padding="15,10" ColumnDefinitions="*, *" BackgroundColor="#F8FAFC">
                                <HorizontalStackLayout Grid.Column="0" HorizontalOptions="Start" Spacing="5">
                                    <Label Text="الرصيد بعدها:" FontSize="11" TextColor="#64748B" VerticalOptions="Center"/>
                                    <Label Text="{Binding PostBalance, StringFormat='{0} ج.م'}" FontSize="11" TextColor="#1E293B" FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="5">
                                    <Label Text="الحالة:" FontSize="11" TextColor="#94A3B8" VerticalOptions="Center"/>
                                    <Label Text="مكتملة ✅" FontSize="11" TextColor="#10B981" FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>