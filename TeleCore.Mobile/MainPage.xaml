<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCore.Mobile.Pages.MainPage"
             Title="الرئيسية">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Frame BorderColor="LightGray" CornerRadius="10" Padding="15" HasShadow="True">
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                    <Ellipse x:Name="StatusDot" WidthRequest="15" HeightRequest="15" Fill="Gray" VerticalOptions="Center"/>
                    <Label x:Name="StatusLabel" Text="جاري الفحص..." FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Text="تحديث" Clicked="OnReconnectClicked" HeightRequest="40" BackgroundColor="#2196F3" CornerRadius="8" Padding="10,0"/>
                </HorizontalStackLayout>
            </Frame>

            <Frame BorderColor="LightGray" CornerRadius="10" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="أرقام الشرائح في هذا الهاتف:" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    <Label Text="افصل بين الأرقام بفاصلة (مثال: 1,2 أو 3)" FontSize="12" TextColor="Gray"/>

                    <Entry x:Name="SimIdsEntry" 
                           Placeholder="مثال: 1,2" 
                           Keyboard="Text" 
                           ClearButtonVisibility="WhileEditing" 
                           HorizontalTextAlignment="Center"/>

                    <Button Text="حفظ وإعادة الاتصال" 
                            Clicked="OnSaveSimSettingsClicked" 
                            BackgroundColor="#4CAF50" 
                            TextColor="White" 
                            CornerRadius="8" 
                            HeightRequest="45" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="تفعيل الأتمتة الذكية (Auto-PIN)"
                    Clicked="OnEnableAccessibilityClicked"
                    BackgroundColor="#FF9800"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>