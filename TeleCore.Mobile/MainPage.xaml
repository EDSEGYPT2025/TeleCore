<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCore.Mobile.MainPage" 
             Title="TeleCore Control Center">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Frame BorderColor="#2196F3" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="حالة الاتصال بالسيرفر" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center"/>
                    <Button x:Name="BtnReconnect" 
                            Text="إعادة الاتصال بالسيرفر" 
                            Clicked="OnReconnectClicked"
                            BackgroundColor="#2196F3"
                            TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#4CAF50" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="إعدادات النظام" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center"/>
                    <Entry x:Name="EntPin" Placeholder="الرقم السري الافتراضي" Keyboard="Numeric"/>
                    <Button Text="حفظ الإعدادات" 
                            Clicked="OnSaveSimSettingsClicked"
                            BackgroundColor="#4CAF50"
                            TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#FF9800" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="خدمة الوصول (Accessibility)" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center"/>
                    <Label Text="يجب تفعيل 'TeleCore Auto-Processor' من إعدادات الهاتف ليعمل التحويل التلقائي" 
                           FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center"/>
                    <Button Text="فتح إعدادات التفعيل" 
                            Clicked="OnEnableAccessibilityClicked"
                            BackgroundColor="#FF9800"
                            TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>