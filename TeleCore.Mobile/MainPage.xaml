<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCore.Mobile.MainPage" 
             Title="[ HQ_COMMAND_UPLINK ]"
             BackgroundColor="#050B14">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Label Text="TELECORE MOBILE NODE :: ACTIVE"
                   TextColor="#00F0FF"
                   FontFamily="monospace"
                   FontSize="13"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   CharacterSpacing="2"/>
            <BoxView HeightRequest="1" Color="#00F0FF" Opacity="0.4" Margin="0,-10,0,10" />

            <Frame BorderColor="#00F0FF" BackgroundColor="#0A1128" CornerRadius="0" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="> RADAR_UPLINK_STATUS" FontFamily="monospace" TextColor="#00F0FF" FontAttributes="Bold" FontSize="15" />

                    <Button x:Name="BtnReconnect" 
                            Text="[ ESTABLISH_CONNECTION ]" 
                            Clicked="OnReconnectClicked"
                            BackgroundColor="Transparent"
                            BorderColor="#00F0FF"
                            BorderWidth="1.5"
                            TextColor="#00F0FF"
                            CornerRadius="0"
                            FontFamily="monospace"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#39FF14" BackgroundColor="#0A1C10" CornerRadius="0" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="> SECURITY_OVERRIDE_PIN" FontFamily="monospace" TextColor="#39FF14" FontAttributes="Bold" FontSize="15" />

                    <Entry x:Name="EntPin" 
                           Placeholder="ENTER_DEFAULT_PIN..." 
                           PlaceholderColor="#1F5C2B"
                           TextColor="#39FF14"
                           BackgroundColor="#050B14"
                           Keyboard="Numeric"
                           FontFamily="monospace"
                           ClearButtonVisibility="WhileEditing"/>

                    <Button Text="[ SAVE_CONFIG ]" 
                            Clicked="OnSaveSimSettingsClicked"
                            BackgroundColor="Transparent"
                            BorderColor="#39FF14"
                            BorderWidth="1.5"
                            TextColor="#39FF14"
                            CornerRadius="0"
                            FontFamily="monospace"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#FF9800" BackgroundColor="#261700" CornerRadius="0" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="> CORE_ACCESS_PROTOCOLS" FontFamily="monospace" TextColor="#FF9800" FontAttributes="Bold" FontSize="15" />

                    <Label Text="SYSTEM REQUIREMENT: 'TeleCore Auto-Processor' MUST BE GRANTED ACCESSIBILITY PRIVILEGES TO EXECUTE AUTO-ROUTING." 
                           FontSize="11" 
                           TextColor="#CC7A00" 
                           FontFamily="monospace"
                           HorizontalTextAlignment="Start"/>

                    <Button Text="[ INITIALIZE_OVERRIDE ]" 
                            Clicked="OnEnableAccessibilityClicked"
                            BackgroundColor="Transparent"
                            BorderColor="#FF9800"
                            BorderWidth="1.5"
                            TextColor="#FF9800"
                            CornerRadius="0"
                            FontFamily="monospace"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>